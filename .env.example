# Copy to .env and fill in. Never commit real secrets.
#
# Horizontal scaling: the default LangGraph MemorySaver is process-local. Run a single
# worker replica unless you configure a shared checkpointer (e.g. Redis / Postgres).

# --- Inference (default: Google Gen AI) ---
STYLIST_LLM_PROVIDER=google_genai
STYLIST_LLM_API_KEY=
# Optional: also accepted at runtime for the default provider
# GOOGLE_API_KEY=

# Optional overrides (defaults are chosen per STYLIST_LLM_PROVIDER when unset)
# STYLIST_CHAT_MODEL=
# STYLIST_EMBEDDING_MODEL=

# Alternative: openai backend (set model ids if not relying on provider defaults)
# STYLIST_LLM_PROVIDER=openai
# STYLIST_LLM_API_KEY=
# STYLIST_CHAT_MODEL=
# STYLIST_EMBEDDING_MODEL=

# --- Runtime ---
STYLIST_ENV=production
STYLIST_DEBUG=false
STYLIST_VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIR=/app/chroma_data
# Index catalog JSON (standalone package): pip install -e ./catalog_feed && digital-stylist-catalog-feed --path ./catalog.json

# HTTP worker (Python)
STYLIST_WORKER_HOST=0.0.0.0
STYLIST_WORKER_PORT=8787
STYLIST_BEHIND_PROXY=true
STYLIST_INVOKE_TIMEOUT_SEC=180
STYLIST_MAX_MESSAGE_CHARS=32000

# Optional: MCP off in locked-down deployments
# STYLIST_MCP_ENABLED=false

# --- PostgreSQL (MCP customer / appointment data; required for seed-* scripts) ---
# HTTP worker: in development (STYLIST_ENV=development or unset), missing STYLIST_PG_* is
# filled with the same defaults as seed CLIs --dev (127.0.0.1:5433, db stylist). Staging/production
# never auto-fill; set STYLIST_PG_* or STYLIST_PG_DSN explicitly. Use STYLIST_PG_DATASTORE=memory to
# disable Postgres for local experiments.
# With docker-compose.yml postgres service (host port 5433):
#   docker compose up -d postgres
#   .venv/bin/digital-stylist-pg-bootstrap   # schema
# STYLIST_PG_HOST=127.0.0.1
# STYLIST_PG_PORT=5433
# STYLIST_PG_DATABASE=stylist
# STYLIST_PG_USER=stylist
# STYLIST_PG_PASSWORD=stylist
# Or: STYLIST_PG_DSN=postgresql://stylist:stylist@127.0.0.1:5433/stylist
# STYLIST_PG_DATASTORE=auto
# Alternatively, seed CLIs accept --dev (same defaults as digital-stylist-pg-bootstrap --dev).

# Express gateway (orchestration)
PORT=3000
STYLIST_WORKER_URL=http://worker:8787
STYLIST_CORS_ORIGINS=https://your-frontend.example
# If storefront apps call orchestration from a different origin (not via Vite proxy):
# STYLIST_CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174
STYLIST_WORKER_TIMEOUT_MS=200000
TRUST_PROXY=true

# Storefront UIs in-repo: apps/clienteling (5173) and apps/connect (5174). Dev servers
# proxy /api and /v1 to orchestration (3000), which proxies /api/* to the worker (8787).
# STYLIST_STOREFRONT_CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174
